# Local (non-Docker) WordPress setup values
WP_PROJECT_DIR=wordpress
WP_SITE_URL=http://localhost/maruti_engineers
WP_SITE_TITLE=Maruti Engineers

# WordPress admin user
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=ChangeThisAdminPassword123!
WP_ADMIN_EMAIL=admin@marutiengineers.local

# MySQL (XAMPP/WAMP/LAMP) values
WP_DB_HOST=127.0.0.1
WP_DB_PORT=3306
WP_DB_NAME=maruti_engineers_db
WP_DB_USER=root
WP_DB_PASSWORD=

# MySQL root credentials used to create DB (often root + empty on fresh XAMPP)
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=
